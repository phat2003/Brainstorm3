@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdeaVM>
@inject UserManager<IdentityUser> UserManager

@{
    var ideas = Model?.ToList() ?? new List<IdeaVM>();
    var now = DateTime.Now;
    var todayStart = now.Date;
    var weekStart = now.Date.AddDays(-((int)now.DayOfWeek == 0 ? 6 : (int)now.DayOfWeek - 1));
    var monthStart = new DateTime(now.Year, now.Month, 1);

    var todayCount = ideas.Count(i => i.idea.CreatedDate >= todayStart);
    var weekCount = ideas.Count(i => i.idea.CreatedDate >= weekStart);
    var monthCount = ideas.Count(i => i.idea.CreatedDate >= monthStart);
}

<div class="home-modern-page">
    <section class="home-hero mb-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div>
                <h2 class="home-title mb-2">Bảng tin Brainstorm</h2>
                <p class="text-muted mb-0">Không gian chia sẻ ý tưởng sáng tạo theo phong cách trẻ trung, nhanh và trực quan.</p>
            </div>
            <a asp-controller="Home" asp-action="Upsert" class="btn btn-primary btn-lg px-4">
                Đóng góp ý tưởng mới
            </a>
        </div>
    </section>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-2">
            @TempData["Error"]
        </div>
    }

    <section class="row g-3 mb-4" aria-label="Thống kê ý tưởng">
        <div class="col-12 col-md-4">
            <div class="metric-card metric-day">
                <div class="metric-label">Hôm nay</div>
                <div class="metric-value">@todayCount</div>
                <div class="metric-hint">ý tưởng mới</div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="metric-card metric-week">
                <div class="metric-label">Tuần này</div>
                <div class="metric-value">@weekCount</div>
                <div class="metric-hint">ý tưởng mới</div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="metric-card metric-month">
                <div class="metric-label">Tháng này</div>
                <div class="metric-value">@monthCount</div>
                <div class="metric-hint">ý tưởng mới</div>
            </div>
        </div>
    </section>

    <section>
        @if (!ideas.Any())
        {
            <div class="empty-state-modern">
                <h5 class="mb-2">Chưa có ý tưởng nào</h5>
                <p class="text-muted mb-3">Hãy bắt đầu bằng một ý tưởng đầu tiên cho cộng đồng.</p>
                <a asp-controller="Home" asp-action="Upsert" class="btn btn-outline-primary">Tạo ý tưởng</a>
            </div>
        }
        else
        {
            @foreach (var idea in ideas.OrderByDescending(x => x.idea.CreatedDate))
            {
                <article class="idea-card-modern mb-4">
                    <div class="card-body p-3 p-md-4">
                        <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <img src="https://ui-avatars.com/api/?name=@idea.idea.ApplicationUser.UserName&background=6f42c1&color=fff"
                                     class="rounded-circle" width="44" height="44" alt="avatar" />
                                <div>
                                    <strong>@idea.idea.ApplicationUser.UserName</strong>
                                    <div class="small text-muted">@idea.idea.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-light text-dark border">Lượt xem: @idea.ViewCount</span>
                                <span class="badge bg-light text-success border">@idea.LikeCount thích</span>
                                <span class="badge bg-light text-danger border">@idea.DislikeCount không thích</span>
                            </div>
                        </div>

                        <p class="idea-content mb-3">@idea.idea.Text</p>

                        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                            @if (idea.react == null || idea.react.ReactValue != 1)
                            {
                                <form asp-area="Staff" asp-controller="Home" asp-action="ReactToIdea" method="post" class="m-0">
                                    <input type="hidden" name="ideaId" value="@idea.idea.Id" />
                                    <input type="hidden" name="reactValue" value="1" />
                                    <button type="submit" class="btn btn-outline-success btn-sm">(@idea.LikeCount) Thích</button>
                                </form>
                            }
                            else
                            {
                                <form asp-area="Staff" asp-controller="Home" asp-action="ReactToIdea" method="post" class="m-0">
                                    <input type="hidden" name="ideaId" value="@idea.idea.Id" />
                                    <input type="hidden" name="reactValue" value="1" />
                                    <button type="submit" class="btn btn-success btn-sm">(@idea.LikeCount) Bỏ thích</button>
                                </form>
                            }

                            @if (idea.react == null || idea.react.ReactValue != -1)
                            {
                                <form asp-area="Staff" asp-controller="Home" asp-action="ReactToIdea" method="post" class="m-0">
                                    <input type="hidden" name="ideaId" value="@idea.idea.Id" />
                                    <input type="hidden" name="reactValue" value="-1" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">(@idea.DislikeCount) Không thích</button>
                                </form>
                            }
                            else
                            {
                                <form asp-area="Staff" asp-controller="Home" asp-action="ReactToIdea" method="post" class="m-0">
                                    <input type="hidden" name="ideaId" value="@idea.idea.Id" />
                                    <input type="hidden" name="reactValue" value="-1" />
                                    <button type="submit" class="btn btn-danger btn-sm">(@idea.DislikeCount) Bỏ không thích</button>
                                </form>
                            }

                            <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#commentSection-@idea.idea.Id" aria-expanded="false" aria-controls="commentSection-@idea.idea.Id">
                                Bình luận (@idea.Comments?.Count())
                            </button>

                            <form asp-action="Views" method="post" class="m-0">
                                <input type="hidden" name="IdeaId" value="@idea.idea.Id" />
                                <input type="hidden" name="VisitTime" value="1" />
                                <button type="submit" class="btn btn-outline-primary btn-sm">Xem chi tiết</button>
                            </form>

                            @if (UserManager.GetUserId(User) == idea.idea.ApplicationUserId)
                            {
                                <a asp-controller="Home" asp-action="Delete" asp-route-id="@idea.idea.Id" class="btn btn-outline-danger btn-sm">Xóa</a>
                            }
                        </div>

                        <div class="collapse" id="commentSection-@idea.idea.Id">
                            <div class="comment-list mb-3">
                                @if (idea.Comments != null && idea.Comments.Any())
                                {
                                    @foreach (var comment in idea.Comments)
                                    {
                                        <div class="comment-item position-relative">
                                            <strong>@(comment.ApplicationUser != null ? comment.ApplicationUser.UserName : "Ẩn danh")</strong>
                                            <small class="text-muted ms-2">@comment.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
                                            <p class="mb-2 mt-1">@comment.Text</p>

                                            @if (UserManager.GetUserId(User) == comment.ApplicationUserId)
                                            {
                                                <div class="d-flex gap-2 flex-wrap">
                                                    <button class="btn btn-outline-primary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#editComment-@comment.Id">Sửa</button>

                                                    <form asp-area="Staff" asp-controller="Home" asp-action="DeleteComment" method="post" class="m-0">
                                                        <input type="hidden" name="commentId" value="@comment.Id" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa bình luận này không?');">Xóa</button>
                                                    </form>
                                                </div>

                                                <div class="collapse mt-2" id="editComment-@comment.Id">
                                                    <form asp-area="Staff" asp-controller="Home" asp-action="UpdateComment" method="post">
                                                        <input type="hidden" name="commentId" value="@comment.Id" />
                                                        <div class="input-group input-group-sm">
                                                            <input type="text" name="newText" class="form-control" value="@comment.Text" required />
                                                            <button type="submit" class="btn btn-success">Lưu</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p class="text-muted small mb-0">Chưa có bình luận nào. Hãy bình luận đầu tiên.</p>
                                }
                            </div>

                            <form asp-area="Staff" asp-controller="Home" asp-action="AddComment" method="post">
                                <input type="hidden" name="IdeaId" value="@idea.idea.Id" />
                                <div class="input-group input-group-sm">
                                    <input type="text" name="Text" class="form-control" placeholder="Viết bình luận của bạn..." required />
                                    <button type="submit" class="btn btn-primary">Gửi</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </article>
            }
        }
    </section>
</div>
