@model IdeaVM

@{
    ViewData["Title"] = "Đóng góp ý tưởng";
}

<div class="container py-3">
    <h2 class="text-primary mb-3">@ViewData["Title"]</h2>
    <p class="text-muted">Điền thông tin bên dưới để gửi ý tưởng mới.</p>

    <div id="closureAlert" class="alert alert-warning d-none" role="alert" aria-live="polite"></div>

    <form id="ideaSubmitForm" class="idea-submit-form" action="/api/ideas" method="post" enctype="multipart/form-data" novalidate>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label for="title" class="form-label">Tiêu đề</label>
                <input id="title" name="title" type="text" maxlength="150" class="form-control" aria-describedby="titleHelp titleError" />
                <div id="titleHelp" class="form-text">Tối đa 150 ký tự.</div>
                <div id="titleError" class="text-danger small" aria-live="polite"></div>
            </div>

            <div class="col-12 col-md-6">
                <label for="departmentId" class="form-label">Khoa</label>
                <select id="departmentId" name="departmentId" class="form-select" aria-describedby="departmentHelp departmentError">
                    <option value="">Đang tải khoa...</option>
                </select>
                <div id="departmentHelp" class="form-text">Vui lòng chọn khoa của bạn.</div>
                <div id="departmentError" class="text-danger small" aria-live="polite"></div>
            </div>

            <div class="col-12">
                <label for="description" class="form-label">Mô tả</label>
                <textarea id="description" name="description" maxlength="5000" rows="5" class="form-control" aria-describedby="descriptionHelp descriptionError"></textarea>
                <div id="descriptionHelp" class="form-text">Nội dung chi tiết ý tưởng (tối đa 5000 ký tự).</div>
                <div id="descriptionError" class="text-danger small" aria-live="polite"></div>
            </div>

            <div class="col-12 col-md-6">
                <label for="categories" class="form-label">Danh mục</label>
                <select id="categories" name="categories" class="form-select" multiple size="6" aria-describedby="categoriesHelp categoriesError">
                    <option value="">Đang tải danh mục...</option>
                </select>
                <div id="categoriesHelp" class="form-text">Giữ Ctrl (hoặc Cmd trên Mac) để chọn nhiều danh mục bằng bàn phím.</div>
                <div id="categoriesError" class="text-danger small" aria-live="polite"></div>
            </div>

            <div class="col-12 col-md-6">
                <label for="tagsInput" class="form-label">Tags</label>
                <input id="tagsInput" name="tagsInput" type="text" class="form-control" placeholder="ví dụ: ui, ux, brainstorm" aria-describedby="tagsHelp tagsError tagsPreview" />
                <div id="tagsHelp" class="form-text">Ngăn cách bằng dấu phẩy. Tối đa gợi ý 10 tags.</div>
                <div id="tagsError" class="text-danger small" aria-live="polite"></div>
                <div id="tagsPreview" class="mt-2 d-flex flex-wrap gap-2"></div>
            </div>

            <div class="col-12 col-md-6">
                <label for="files" class="form-label">Tài liệu đính kèm</label>
                <input id="files" name="files" type="file" class="form-control" multiple aria-describedby="filesHelp filesError fileList" />
                <div id="filesHelp" class="form-text">Tối đa 5 file, mỗi file không quá 10MB.</div>
                <div id="filesError" class="text-danger small" aria-live="polite"></div>
                <ul id="fileList" class="list-group list-group-flush mt-2"></ul>
            </div>

            <div class="col-12 col-md-6">
                <div class="form-check mb-2">
                    <input id="anonymous" name="anonymous" type="checkbox" class="form-check-input" />
                    <label for="anonymous" class="form-check-label">Đăng ẩn danh</label>
                </div>

                <div class="form-check">
                    <input id="agreeTerms" name="agreeTerms" type="checkbox" class="form-check-input" aria-describedby="agreeTermsError" />
                    <label for="agreeTerms" class="form-check-label">Tôi đồng ý với Điều khoản</label>
                </div>
                <div id="agreeTermsError" class="text-danger small" aria-live="polite"></div>
            </div>

            <div class="col-12">
                <div class="progress d-none" id="uploadProgressWrapper" role="status" aria-live="polite">
                    <div id="uploadProgressBar" class="progress-bar" role="progressbar" style="width: 0%">0%</div>
                </div>
            </div>

            <div class="col-12 d-flex gap-2 flex-wrap">
                <button id="submitButton" type="submit" class="btn btn-primary">Gửi ý tưởng</button>
                <button id="resetButton" type="reset" class="btn btn-outline-secondary">Làm mới</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </div>
    </form>

    <div id="formStatus" class="mt-3" aria-live="polite"></div>
</div>

@section Scripts {
    <script src="~/js/idea-submit.js" asp-append-version="true"></script>
}
