@{
    ViewData["Title"] = "Chính sách quyền riêng tư";
}

<div class="privacy-modern-page">
    <div class="privacy-hero mb-4">
        <h1 class="mb-2">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">Brainstorm cam kết bảo vệ dữ liệu cá nhân và tạo môi trường chia sẻ ý tưởng an toàn.</p>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <section class="privacy-card h-100">
                <h5>Thông tin được thu thập</h5>
                <ul class="mb-0">
                    <li>Thông tin tài khoản khi đăng nhập.</li>
                    <li>Nội dung ý tưởng, bình luận và tệp đính kèm bạn gửi.</li>
                    <li>Dữ liệu thống kê tương tác để cải thiện trải nghiệm.</li>
                </ul>
            </section>
        </div>

        <div class="col-12 col-md-6">
            <section class="privacy-card h-100">
                <h5>Mục đích sử dụng dữ liệu</h5>
                <ul class="mb-0">
                    <li>Hiển thị và quản lý ý tưởng trong hệ thống.</li>
                    <li>Hỗ trợ phản hồi, đánh giá và cộng tác nội bộ.</li>
                    <li>Tăng chất lượng sản phẩm và tính năng nền tảng.</li>
                </ul>
            </section>
        </div>

        <div class="col-12">
            <section class="privacy-card">
                <h5>Bảo mật và liên hệ</h5>
                <p class="mb-2">Dữ liệu được quản lý theo quyền truy cập và chính sách bảo mật nội bộ.</p>
                <p class="mb-0">Nếu cần hỗ trợ, vui lòng liên hệ quản trị viên hệ thống Brainstorm.</p>
            </section>
        </div>
    </div>
</div>
