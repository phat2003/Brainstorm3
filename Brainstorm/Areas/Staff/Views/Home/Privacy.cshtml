@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="privacy-modern-page">
    <div class="privacy-hero mb-4">
        <h1 class="mb-2">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">Brainstorm is committed to protecting personal data and providing a safe environment for idea sharing.</p>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <section class="privacy-card h-100">
                <h5>Information We Collect</h5>
                <ul class="mb-0">
                    <li>Account information used for sign-in.</li>
                    <li>Ideas, comments, and attachments you submit.</li>
                    <li>Interaction analytics used to improve experience.</li>
                </ul>
            </section>
        </div>

        <div class="col-12 col-md-6">
            <section class="privacy-card h-100">
                <h5>How We Use Data</h5>
                <ul class="mb-0">
                    <li>Display and manage ideas within the system.</li>
                    <li>Support feedback, review, and internal collaboration.</li>
                    <li>Improve platform quality and features.</li>
                </ul>
            </section>
        </div>

        <div class="col-12">
            <section class="privacy-card">
                <h5>Security and Contact</h5>
                <p class="mb-2">Data is governed by role-based access control and internal security policies.</p>
                <p class="mb-0">If you need support, please contact your Brainstorm system administrator.</p>
            </section>
        </div>
    </div>
</div>
