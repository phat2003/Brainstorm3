@model View

@{
    ViewData["Title"] = "Chi tiết ý tưởng";
}

<div class="detail-modern-page">
    <div class="detail-header mb-3">
        <h2 class="mb-1">@ViewData["Title"]</h2>
        <p class="text-muted mb-0">Xem đầy đủ nội dung, danh mục và tệp đính kèm của ý tưởng.</p>
    </div>

    <article class="detail-card">
        <div class="row g-3">
            <div class="col-12">
                <div class="detail-label">Nội dung</div>
                <div class="detail-value">@Model.Idea.Text</div>
            </div>

            <div class="col-12 col-md-6">
                <div class="detail-label">Danh mục</div>
                <div class="detail-value">@Model.Idea.Category?.Name</div>
            </div>

            <div class="col-12 col-md-6">
                <div class="detail-label">Chủ đề</div>
                <div class="detail-value">@Model.Idea.Topic?.Name</div>
            </div>

            <div class="col-12 col-md-6">
                <div class="detail-label">Ngày tạo</div>
                <div class="detail-value">@Model.Idea.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Idea.FilePath))
            {
                <div class="col-12 col-md-6">
                    <div class="detail-label">Tệp đính kèm</div>
                    <div class="detail-value">
                        <a href="~/@Model.Idea.FilePath" target="_blank" class="btn btn-outline-primary btn-sm">Xem file</a>
                    </div>
                </div>
            }
        </div>

        <div class="mt-4 d-flex gap-2 flex-wrap">
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            <a asp-action="Upsert" asp-route-id="@Model.Idea.Id" class="btn btn-outline-primary">Chỉnh sửa</a>
        </div>
    </article>
</div>
