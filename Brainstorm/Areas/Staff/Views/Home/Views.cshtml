@model View

@{
    ViewData["Title"] = "Idea Details";
}

<div class="detail-modern-page">
    <div class="detail-header mb-3">
        <h2 class="mb-1">@ViewData["Title"]</h2>
        <p class="text-muted mb-0">See the full content, category, topic, and attachment of this idea.</p>
    </div>

    <article class="detail-card">
        <div class="row g-3">
            <div class="col-12">
                <div class="detail-label">Content</div>
                <div class="detail-value">@Model.Idea.Text</div>
            </div>

            <div class="col-12 col-md-6">
                <div class="detail-label">Category</div>
                <div class="detail-value">@Model.Idea.Category?.Name</div>
            </div>

            <div class="col-12 col-md-6">
                <div class="detail-label">Topic</div>
                <div class="detail-value">@Model.Idea.Topic?.Name</div>
            </div>

            <div class="col-12 col-md-6">
                <div class="detail-label">Created At</div>
                <div class="detail-value">@Model.Idea.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Idea.FilePath))
            {
                <div class="col-12 col-md-6">
                    <div class="detail-label">Attachment</div>
                    <div class="detail-value">
                        <a href="~/@Model.Idea.FilePath" target="_blank" class="btn btn-outline-primary btn-sm">Open file</a>
                    </div>
                </div>
            }
        </div>

        <div class="mt-4 d-flex gap-2 flex-wrap">
            <a asp-action="Index" class="btn btn-secondary">Back</a>
            <a asp-action="Upsert" asp-route-id="@Model.Idea.Id" class="btn btn-outline-primary">Edit</a>
        </div>
    </article>
</div>
