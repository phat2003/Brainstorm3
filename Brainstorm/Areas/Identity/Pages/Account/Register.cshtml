@page
@model RegisterModel
@{
    var onlyAdminBootstrap = Model.Input?.RoleList?.Count() == 1 && Model.Input.Role == "Admin";
    var isAdminAddUser = User.Identity?.IsAuthenticated == true && User.IsInRole("Admin");
    ViewData["Title"] = isAdminAddUser ? "Add User" : "Register";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-6">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2>@(isAdminAddUser ? "Create a new user account." : "Create a new account.")</h2>
            <hr />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            @if (onlyAdminBootstrap)
            {
                <input type="hidden" asp-for="Input.Role" />
                <div class="alert alert-info py-2">No admin account exists yet. This account will be created as Admin.</div>
            }
            else
            {
                <div class="form-floating py-2 col-6">
                    <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select" id="Input_Role">
                        <option disabled selected>-Select Role</option>
                    </select>
                </div>
            }

            <div class="form-floating py-2 col-6">
                <select asp-for="Input.DepartmentId" style="display:none" asp-items="@Model.Input.DepartmentList" class="form-select" id="Input_DepartmentId">
                    <option disabled selected>-Select Department</option>
                </select>
            </div>

            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">@(isAdminAddUser ? "Add User" : "Register")</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const syncDepartment = function () {
                var selection = $('#Input_Role option:selected').text();
                if (selection === 'Admin') {
                    $('#Input_DepartmentId').hide();
                } else {
                    $('#Input_DepartmentId').show();
                }
            };

            $('#Input_Role').change(syncDepartment);
            syncDepartment();
        });
    </script>
}
