@model IdeaVM

@{
    var isEdit = Model?.idea?.Id > 0;
    ViewData["Title"] = isEdit ? "Update Idea" : "Submit Idea";
}

<div class="home-modern-page">
    <section class="home-hero mb-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div>
                <h2 class="home-title mb-2">@ViewData["Title"]</h2>
                <p class="text-muted mb-0">Fill in the details below and submit your idea.</p>
            </div>
        </div>
    </section>

    <form asp-action="Upsert" method="post" enctype="multipart/form-data" class="idea-submit-form">
        @if (isEdit)
        {
            <input asp-for="idea.Id" type="hidden" />
        }

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="idea.Text" class="form-label">Content</label>
            <textarea asp-for="idea.Text" class="form-control" rows="5" placeholder="Describe your idea..." required></textarea>
            <span asp-validation-for="idea.Text" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label asp-for="idea.CategoryId" class="form-label">Category</label>
                <select asp-for="idea.CategoryId" asp-items="Model.CategoryList" class="form-select" required>
                    <option value="">-- Select category --</option>
                </select>
                <span asp-validation-for="idea.CategoryId" class="text-danger"></span>
            </div>

            <div class="col-12 col-md-6">
                <label asp-for="idea.TopicId" class="form-label">Topic</label>
                <select asp-for="idea.TopicId" asp-items="Model.TopicList" class="form-select" required>
                    <option value="">-- Select topic --</option>
                </select>
                <span asp-validation-for="idea.TopicId" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-3 mb-3">
            <label class="form-label">Attachment (optional)</label>
            <input type="file" name="filepath" class="form-control" />
            @if (!string.IsNullOrEmpty(Model?.idea?.FilePath))
            {
                <div class="form-text mt-1">
                    Current file: <a href="~/@Model.idea.FilePath" target="_blank">Open file</a>
                </div>
            }
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-primary">@(isEdit ? "Update" : "Submit Idea")</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
