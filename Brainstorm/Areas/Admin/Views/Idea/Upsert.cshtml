@model IdeaVM

@{
    ViewData["Title"] = Model.idea.Id == 0 ? "Create Idea" : "Update Idea";
    var isEdit = Model.idea.Id != 0;
}

<div class="container p-3">
    <h2 class="text-primary">@ViewData["Title"]</h2>
    <hr />
    <form asp-action="Upsert" enctype="multipart/form-data" method="post">
        @if (isEdit)
        {
            @Html.HiddenFor(m => m.idea.Id)
        }
        <div class="mb-3">
            <label asp-for="idea.Text" class="form-label"></label>
            <textarea asp-for="idea.Text" class="form-control"></textarea>
            <span asp-validation-for="idea.Text" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="idea.CategoryId" class="form-label"></label>
            <select asp-for="idea.CategoryId" class="form-select" asp-items="Model.CategoryList">
                <option value="">-- Select Category --</option>
            </select>
            <span asp-validation-for="idea.CategoryId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="idea.TopicId" class="form-label"></label>
            <select asp-for="idea.TopicId" class="form-select" asp-items="Model.TopicList">
                <option value="">-- Select Topic --</option>
            </select>
            <span asp-validation-for="idea.TopicId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Attachment (optional)</label>
            <input type="file" name="filepath" class="form-control" />
            @if (!string.IsNullOrEmpty(Model.idea.FilePath))
            {
                <div class="mt-2">
                    <span>Current file: </span>
                    <a href="~/@Model.idea.FilePath" target="_blank">Open file</a>
                </div>
            }
        </div>
        <button type="submit" class="btn btn-primary">@(Model.idea.Id == 0 ? "Create" : "Update")</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
