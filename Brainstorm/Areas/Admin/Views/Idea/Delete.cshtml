@model Idea

@{
    ViewData["Title"] = "Delete Idea";
}

<div class="container p-3">
    <h2 class="text-danger">@ViewData["Title"]</h2>
    <hr />
    <h4>Are you sure you want to delete this idea?</h4>
    <dl class="row">
        <dt class="col-sm-2">Content</dt>
        <dd class="col-sm-10">@Model.Text</dd>

        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Category?.Name</dd>

        <dt class="col-sm-2">Topic</dt>
        <dd class="col-sm-10">@Model.Topic?.Name</dd>

        <dt class="col-sm-2">Created Date</dt>
        <dd class="col-sm-10">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</dd>

        @if (!string.IsNullOrEmpty(Model.FilePath))
        {
            <dt class="col-sm-2">Attachment</dt>
            <dd class="col-sm-10">
                <a href="~/@Model.FilePath" target="_blank">Open file</a>
            </dd>
        }
    </dl>
    <form asp-action="DeletePost" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>
