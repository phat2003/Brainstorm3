@model IEnumerable<UserRoleVM>

<div class="container p-3">
    @if (TempData["success"] != null)
    {
        <div class="alert alert-success">@TempData["success"]</div>
    }
    @if (TempData["error"] != null)
    {
        <div class="alert alert-danger">@TempData["error"]</div>
    }

    <div class="row pt-4">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h2 class="text-primary m-0">Danh sách Người dùng</h2>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary">Thêm user</a>
        </div>
    </div>

    <br />

    <table class="table table-bordered table-striped align-middle" style="width:100%">
        <thead>
            <tr>
                <th>Tên đăng nhập (UserName)</th>
                <th>Vai trò (Role)</th>
                <th>Department</th>
                <th class="text-nowrap">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.UserName</td>
                    <td>@item.Role</td>
                    <td>@item.DepartmentName</td>
                    <td class="text-nowrap">
                        <a asp-controller="User" asp-action="EditRole" asp-route-userId="@item.UserId" class="btn btn-success btn-sm mx-1">
                            Phân quyền
                        </a>
                        <a asp-controller="User" asp-action="ResetPassword" asp-route-userId="@item.UserId" class="btn btn-warning btn-sm mx-1">
                            Reset mật khẩu
                        </a>
                        <a asp-controller="User" asp-action="Delete" asp-route-userId="@item.UserId" class="btn btn-danger btn-sm mx-1">
                            Xoá
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>