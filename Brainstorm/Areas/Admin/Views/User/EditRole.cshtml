@model Brainstorm.Models.ViewModel.RoleManagementVM

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Update User (Role + Department)</h2>
        </div>
    </div>
    <br />

    <form method="post" action="EditRole">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="User.Id" name="userId" />

        <div class="mb-3">
            <label class="form-label">Username</label>
            <input asp-for="User.UserName" class="form-control" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Select New Role</label>
            <select name="newRole" asp-items="@Model.RoleList" class="form-select" id="newRoleSelect">
                <option disabled>-- Select Role --</option>
            </select>
        </div>

        <div class="mb-3 d-none" id="departmentWrapper">
            <label class="form-label">Department</label>
            <select name="departmentId" asp-items="@Model.DepartmentList" class="form-select" id="departmentSelect">
                <option value="">-- Select Department --</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Back to list</a>
    </form>
</div>

@section Scripts {
    <script>
        (() => {
            const roleSelect = document.getElementById('newRoleSelect');
            const departmentWrapper = document.getElementById('departmentWrapper');
            const departmentSelect = document.getElementById('departmentSelect');
            if (!roleSelect || !departmentWrapper || !departmentSelect) return;

            const sync = () => {
                const selectedRole = roleSelect.value;
                if (selectedRole === 'Admin') {
                    departmentWrapper.classList.add('d-none');
                    departmentSelect.value = '';
                } else {
                    departmentWrapper.classList.remove('d-none');
                }
            };

            roleSelect.addEventListener('change', sync);
            sync();
        })();
    </script>
}