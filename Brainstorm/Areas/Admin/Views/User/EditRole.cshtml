@model Brainstorm.Models.ViewModel.RoleManagementVM

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Phân quyền Người dùng</h2>
        </div>
    </div>
    <br />

    <form method="post" action="EditRole">
        <input type="hidden" asp-for="User.Id" name="userId" />

        <div class="mb-3">
            <label class="form-label">Tên đăng nhập (UserName)</label>
            <input asp-for="User.UserName" class="form-control" readonly />
        </div>

        <div class="mb-3">
            <label class="form-label">Chọn Vai trò mới</label>
            <select name="newRole" asp-items="@Model.RoleList" class="form-select">
                <option disabled selected>-- Chọn Vai trò --</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">Cập nhật</button>
        <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
    </form>
</div>